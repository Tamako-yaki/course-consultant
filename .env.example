# ===================== Milvus 向量資料庫 =====================
MILVUS_HOST=your_milvus_host                        # Milvus 服務的主機位址（e.g., localhost）
MILVUS_PORT=your_milvus_port                        # Milvus 服務的埠號（預設 19530）
MILVUS_COLLECTION_NAME=your_collection_name         # 要使用的 Collection 名稱

# ===================== API 金鑰 =====================
HF_TOKEN=your_huggingface_token                     # HuggingFace API Token，用於下載私有模型
GEMINI_API_KEY=your_gemini_api_key                  # Google Gemini API 金鑰，用於 LLM 生成
GEMINI_MODEL=your_gemini_model                      # Google Gemini 模型名稱（e.g., gemini-2.0-flash）

# ===================== FastAPI 伺服器 =====================
HOST=your_host                                      # API 伺服器監聽的主機位址（e.g., 0.0.0.0）
PORT=your_port                                      # API 伺服器監聽的埠號（e.g., 8000）

# ===================== Embedding 模型 =====================
EMBEDDING_DEVICE=your_embedding_device              # 執行 Embedding 模型的裝置 (e.g., cpu or cuda)

# ===================== 抑制終端雜訊 =====================
HF_HUB_DISABLE_PROGRESS_BARS=1                      # 關閉 HuggingFace Hub 模型下載進度條
FLAGEMBEDDING_IGNORE_LOADING_REPORT=1               # 關閉 FlagEmbedding 模型載入報告（UNEXPECTED keys 等）
TRANSFORMERS_VERBOSITY=error                        # 將 HuggingFace Transformers 日誌等級設為僅顯示錯誤
TRANSFORMERS_NO_ADVISORY_WARNINGS=1                 # 關閉 Transformers 的建議性警告訊息